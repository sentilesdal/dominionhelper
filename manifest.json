{
  "manifest_version": 3,
  "name": "Dominion Helper",
  "version": "0.2.0",
  "description": "Analyzes Dominion Online kingdoms for card synergies, strategy archetypes, and opening recommendations.",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["https://dominion.games/*"],
  "content_scripts": [
    {
      "matches": ["https://dominion.games/*"],
      "js": [
        "src/data/cards-bundle.js",
        "src/analysis/synergies.js",
        "src/analysis/archetypes.js",
        "src/analysis/engine.js",
        "src/content/observer.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
